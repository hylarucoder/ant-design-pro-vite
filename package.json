{
  "name": "ant-design-pro-vite",
  "version": "6.0.0",
  "private": true,
  "description": "An out-of-box UI solution for enterprise applications",
  "repository": "git@github.com:ant-design/ant-design-pro.git",
  "scripts": {
    "build": "vite build",
    "deploy": "pnpm build && pnpm gh-pages",
    "dev": "vite --host 0.0.0.0 --port 8000",
    "format": "oxfmt -c .oxfmtrc.json .",
    "format:check": "oxfmt -c .oxfmtrc.json --check .",
    "gh-pages": "gh-pages -d dist",
    "lint": "pnpm format:check && pnpm oxlint && pnpm typecheck",
    "lint:fix": "pnpm format && pnpm oxlint:fix",
    "lint-staged": "lint-staged",
    "oxlint": "oxlint -c .oxlintrc.json .",
    "oxlint:fix": "oxlint -c .oxlintrc.json . --fix",
    "prepare": "husky",
    "preview": "vite preview --host 0.0.0.0 --port 8000",
    "serve": "vite preview --host 0.0.0.0 --port 8000",
    "start": "vite --host 0.0.0.0 --port 8000",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --passWithNoTests --coverage",
    "test:update": "vitest run --passWithNoTests -u",
    "tsc": "pnpm typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.vite.json"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@ant-design/plots": "^2.6.0",
    "@ant-design/pro-components": "^2.7.19",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@antv/l7": "^2.22.7",
    "@antv/l7-react": "^2.4.3",
    "antd": "^5.25.4",
    "antd-style": "^3.7.0",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.13",
    "numeral": "^2.0.6",
    "rc-util": "^5.44.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.1",
    "@types/lodash": "^4.17.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "gh-pages": "^6.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "less": "^4.6.4",
    "lint-staged": "^16.1.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "browserslist": [
    "defaults"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
