{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["vite/client", "node", "vitest/globals"],
    "declaration": false,
    "paths": {
      "@/*": ["./*"],
      "@ant-design/pro-card": ["./pro-components/card/es/index"],
      "@ant-design/pro-components": ["./pro-components/index.ts"],
      "@ant-design/pro-descriptions": ["./pro-components/descriptions/index.tsx"],
      "@ant-design/pro-field": ["./pro-components/field/es/index"],
      "@ant-design/pro-form": ["./pro-components/form/es/index"],
      "@ant-design/pro-layout": ["./pro-components/layout/index.tsx"],
      "@ant-design/pro-provider": ["./pro-components/provider/es/index"],
      "@ant-design/pro-skeleton": ["./pro-components/skeleton/es/index"],
      "@ant-design/pro-table": ["./pro-components/table/index.tsx"],
      "@ant-design/pro-utils": ["./pro-components/utils/es/index"]
    }
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "src/typings.d.ts",
    "src/vite-env.d.ts",
    "src/global.less",
    "src/app.tsx",
    "src/main.tsx",
    "src/data/**/*.ts",
    "src/hooks/**/*.ts",
    "src/layout/**/*.tsx",
    "src/pages/**/*.ts",
    "src/pages/**/*.tsx",
    "src/pro-components/**/*.ts",
    "src/pro-components/**/*.tsx",
    "src/services/**/*.ts",
    "src/types/**/*.ts",
    "src/components/**/*.tsx",
    "tests/**/*.ts"
  ],
  "exclude": ["src/.umi/**", "src/locales/**"]
}
